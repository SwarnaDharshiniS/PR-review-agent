{
  "name": "pr_review_workflow",
  "description": "Takes a GitHub PR URL, sends it to the pr_review_agent, and stores the result.",
  "start": { "type": "MANUAL" },
  "nodes": [
    {
      "id": "intake",
      "type": "FORM",
      "label": "PR URL Input",
      "config": {
        "input_schema": {
          "type": "object",
          "properties": {
            "pr_url": { "type": "string", "description": "GitHub PR URL to review" }
          },
          "required": ["pr_url"]
        }
      }
    },
    {
      "id": "review",
      "type": "AGENT",
      "label": "Review PR",
      "config": {
        "agent_name": "pr_review_agent",
        "input_mapping": {
          "pr_url": { "type": "expression", "value": "intake.pr_url" }
        }
      }
    },
    { "id": "end", "type": "END", "label": "Done" }
  ],
  "edges": [
    { "id": "e1", "source": "intake", "target": "review" },
    { "id": "e2", "source": "review", "target": "end" }
  ],
  "visibility": "POD"
}
