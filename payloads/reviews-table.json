{
  "name": "pr_reviews",
  "description": "Stores all PR reviews generated by the pr_review_agent",
  "columns": [
    { "name": "pr_url",       "type": "TEXT",      "description": "GitHub PR URL" },
    { "name": "pr_title",     "type": "TEXT",      "description": "PR title" },
    { "name": "author",       "type": "TEXT",      "description": "PR author GitHub username" },
    { "name": "verdict",      "type": "TEXT",      "description": "APPROVE | REQUEST_CHANGES | NEEDS_DISCUSSION" },
    { "name": "summary",      "type": "TEXT",      "description": "2-3 sentence summary of the PR" },
    { "name": "bug_count",    "type": "INTEGER",   "description": "Number of bugs found" },
    { "name": "security_count","type": "INTEGER",  "description": "Number of security issues found" },
    { "name": "style_count",  "type": "INTEGER",   "description": "Number of style issues found" },
    { "name": "full_review",  "type": "TEXT",      "description": "Full JSON review output from agent" },
    { "name": "status",       "type": "TEXT",      "description": "PENDING | COMPLETE | ERROR", "default": "PENDING" }
  ]
}
